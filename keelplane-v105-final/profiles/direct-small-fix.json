{
  "schema_version": "1.0.0",
  "id": "direct-small-fix",
  "version": "1.0.0",
  "description": "One writer with focused checks and optional fresh review.",
  "activation": {
    "requires": [
      "one ownership region",
      "localized acceptance claim"
    ],
    "forbids": [
      "two independent writers",
      "cross-module migration"
    ]
  },
  "limits": {
    "max_threads": 2,
    "max_writers": 1,
    "max_retries_per_role": 1
  },
  "roles": [
    {
      "role": "lead",
      "required": true,
      "parallel_group": null,
      "trigger": null
    },
    {
      "role": "code-reviewer",
      "required": false,
      "parallel_group": null,
      "trigger": "nontrivial or risky diff"
    }
  ],
  "flow": [
    "lead implements",
    "focused verification",
    "optional fresh review",
    "capture"
  ],
  "required_evidence": [
    "current source snapshot",
    "focused check or explicit not-run reason",
    "diff/status",
    "capture seal"
  ],
  "downgrade": {
    "target": "direct-native-agent",
    "conditions": [
      "always remains direct"
    ]
  }
}
