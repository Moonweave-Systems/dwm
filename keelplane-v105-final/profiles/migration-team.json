{
  "schema_version": "1.0.0",
  "id": "migration-team",
  "version": "1.0.0",
  "description": "Two isolated writers with a frozen interface contract and integration owner.",
  "activation": {
    "requires": [
      "two independent workstreams",
      "stable interface contract",
      "worktree isolation"
    ],
    "forbids": [
      "high shared-file ratio",
      "unstable shared schema"
    ]
  },
  "limits": {
    "max_threads": 5,
    "max_writers": 2,
    "max_retries_per_role": 1
  },
  "roles": [
    {
      "role": "explorer",
      "required": true,
      "parallel_group": null,
      "trigger": "mapper/interface contract"
    },
    {
      "role": "implementer",
      "required": true,
      "parallel_group": "writer-fanout",
      "trigger": "ownership A"
    },
    {
      "role": "implementer",
      "required": true,
      "parallel_group": "writer-fanout",
      "trigger": "ownership B"
    },
    {
      "role": "lead",
      "required": true,
      "parallel_group": null,
      "trigger": "integration owner"
    },
    {
      "role": "test-verifier",
      "required": true,
      "parallel_group": null,
      "trigger": "fan-in"
    },
    {
      "role": "code-reviewer",
      "required": true,
      "parallel_group": null,
      "trigger": "integrated snapshot"
    }
  ],
  "flow": [
    "map and freeze interface",
    "parallel isolated writers",
    "integration owner merges",
    "integration checks",
    "fresh review",
    "capture"
  ],
  "required_evidence": [
    "interface contract",
    "worktree/ownership records",
    "both writer results",
    "integrated source digest",
    "integration receipts",
    "fresh review",
    "capture seal"
  ],
  "downgrade": {
    "target": "feature-pipeline",
    "conditions": [
      "semantic coupling or shared files make parallelism unsafe"
    ]
  }
}
