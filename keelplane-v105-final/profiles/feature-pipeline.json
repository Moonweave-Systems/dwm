{
  "schema_version": "1.0.0",
  "id": "feature-pipeline",
  "version": "1.0.0",
  "description": "Default nontrivial feature/bug workflow with one writer and independent checks.",
  "activation": {
    "requires": [
      "nontrivial code path",
      "one primary write ownership",
      "separable verification"
    ],
    "forbids": [
      "same-file parallel writers"
    ]
  },
  "limits": {
    "max_threads": 4,
    "max_writers": 1,
    "max_retries_per_role": 1
  },
  "roles": [
    {
      "role": "explorer",
      "required": true,
      "parallel_group": null,
      "trigger": null
    },
    {
      "role": "implementer",
      "required": true,
      "parallel_group": null,
      "trigger": null
    },
    {
      "role": "test-verifier",
      "required": true,
      "parallel_group": "post-implementation-review",
      "trigger": null
    },
    {
      "role": "code-reviewer",
      "required": true,
      "parallel_group": "post-implementation-review",
      "trigger": null
    },
    {
      "role": "security-reviewer",
      "required": false,
      "parallel_group": "post-implementation-review",
      "trigger": "security-sensitive surface"
    },
    {
      "role": "adversarial-reviewer",
      "required": false,
      "parallel_group": "post-implementation-review",
      "trigger": "concurrency, stale state, or high consequence"
    }
  ],
  "flow": [
    "explore",
    "implement",
    "freeze diff digest",
    "verify and review in parallel",
    "adjudicate",
    "capture"
  ],
  "required_evidence": [
    "explorer result",
    "current diff/source digest",
    "observed test receipt",
    "fresh review",
    "gate events when triggered",
    "capture seal"
  ],
  "downgrade": {
    "target": "direct-small-fix",
    "conditions": [
      "localized one-file/one-symbol change",
      "coordination cost exceeds expected benefit"
    ]
  }
}
