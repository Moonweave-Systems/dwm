{
  "schema_version": "1.0.0",
  "id": "cross-harness-review",
  "version": "1.0.0",
  "description": "Implementation in one native harness and blind-first review in the other.",
  "activation": {
    "requires": [
      "two native subscriptions available",
      "medium/high-risk change"
    ],
    "forbids": [
      "reviewer receives implementation rationale before first findings"
    ]
  },
  "limits": {
    "max_threads": 2,
    "max_writers": 1,
    "max_retries_per_role": 1
  },
  "roles": [
    {
      "role": "implementer",
      "required": true,
      "parallel_group": null,
      "trigger": null
    },
    {
      "role": "code-reviewer",
      "required": true,
      "parallel_group": null,
      "trigger": "different harness"
    }
  ],
  "flow": [
    "implement in harness A",
    "freeze diff/source digest",
    "review in harness B",
    "adjudicate",
    "capture"
  ],
  "required_evidence": [
    "producer result",
    "exact scope digest",
    "cross-harness review",
    "observed checks",
    "capture seal"
  ],
  "downgrade": {
    "target": "feature-pipeline",
    "conditions": [
      "only one harness is available"
    ]
  }
}
