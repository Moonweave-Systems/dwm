{
  "schema_version": "1.0.0",
  "id": "parallel-audit",
  "version": "1.0.0",
  "description": "Read-only multi-angle audit with independent failure modes and synthesis.",
  "activation": {
    "requires": [
      "read-only task",
      "multiple independent failure modes"
    ],
    "forbids": [
      "unapproved remediation writes"
    ]
  },
  "limits": {
    "max_threads": 4,
    "max_writers": 0,
    "max_retries_per_role": 1
  },
  "roles": [
    {
      "role": "explorer",
      "required": true,
      "parallel_group": null,
      "trigger": null
    },
    {
      "role": "code-reviewer",
      "required": true,
      "parallel_group": "audit-fanout",
      "trigger": "correctness/compatibility"
    },
    {
      "role": "security-reviewer",
      "required": true,
      "parallel_group": "audit-fanout",
      "trigger": "security"
    },
    {
      "role": "adversarial-reviewer",
      "required": true,
      "parallel_group": "audit-fanout",
      "trigger": "counterexamples"
    }
  ],
  "flow": [
    "map surfaces",
    "parallel read-only reviews",
    "deduplicate and challenge findings",
    "capture"
  ],
  "required_evidence": [
    "surface map",
    "scope-bound reviews",
    "finding evidence",
    "capture seal"
  ],
  "downgrade": {
    "target": "single-reviewer-audit",
    "conditions": [
      "only one failure mode or one small surface"
    ]
  }
}
