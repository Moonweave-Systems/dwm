{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://moonweave.systems/keelplane/schemas/team-profile-1.0.0.json",
  "title": "Keelplane Team Profile",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "version",
    "description",
    "activation",
    "limits",
    "roles",
    "flow",
    "required_evidence",
    "downgrade"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "version": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "activation": {
      "type": "object",
      "required": [
        "requires",
        "forbids"
      ],
      "properties": {
        "requires": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "forbids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "limits": {
      "type": "object",
      "required": [
        "max_threads",
        "max_writers",
        "max_retries_per_role"
      ],
      "properties": {
        "max_threads": {
          "type": "integer",
          "minimum": 1,
          "maximum": 8
        },
        "max_writers": {
          "type": "integer",
          "minimum": 0,
          "maximum": 3
        },
        "max_retries_per_role": {
          "type": "integer",
          "minimum": 0,
          "maximum": 2
        }
      },
      "additionalProperties": false
    },
    "roles": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "role",
          "required",
          "parallel_group"
        ],
        "properties": {
          "role": {
            "type": "string"
          },
          "required": {
            "type": "boolean"
          },
          "parallel_group": {
            "type": [
              "string",
              "null"
            ]
          },
          "trigger": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "additionalProperties": false
      }
    },
    "flow": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "required_evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "downgrade": {
      "type": "object",
      "required": [
        "target",
        "conditions"
      ],
      "properties": {
        "target": {
          "type": "string"
        },
        "conditions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    }
  }
}
