{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://moonweave.systems/keelplane/schemas/run-contract-1.0.0.json",
  "title": "Keelplane Run Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "plan",
    "target",
    "capabilities",
    "profile",
    "workers",
    "claims",
    "risk_gates",
    "budgets",
    "compile_report_sha256"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "run_id": {
      "type": "string"
    },
    "plan": {
      "type": "object",
      "required": [
        "path",
        "sha256",
        "schema_version"
      ],
      "properties": {
        "path": {
          "type": "string"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "schema_version": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "target": {
      "type": "object",
      "required": [
        "harness",
        "version"
      ],
      "properties": {
        "harness": {
          "type": "string"
        },
        "version": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "capabilities": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source",
        "snapshot_sha256",
        "features"
      ],
      "properties": {
        "source": {
          "type": "string",
          "minLength": 1
        },
        "snapshot_sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "features": {
          "type": "object",
          "additionalProperties": {
            "enum": [
              "supported",
              "experimental",
              "unsupported",
              "unknown"
            ]
          }
        }
      }
    },
    "profile": {
      "type": "object",
      "required": [
        "id",
        "version"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "version": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "workers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "worker_id",
          "native_agent",
          "role",
          "read_scope",
          "write_scope"
        ],
        "properties": {
          "worker_id": {
            "type": "string"
          },
          "native_agent": {
            "type": "string"
          },
          "role": {
            "type": "string"
          },
          "read_scope": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "write_scope": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      }
    },
    "claims": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "claim_id",
          "statement",
          "falsifier",
          "required_evidence",
          "minimum_assurance",
          "evaluator",
          "hard"
        ],
        "properties": {
          "claim_id": {
            "type": "string",
            "minLength": 1
          },
          "statement": {
            "type": "string",
            "minLength": 1
          },
          "falsifier": {
            "type": "string",
            "minLength": 1
          },
          "required_evidence": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "minItems": 1
          },
          "minimum_assurance": {
            "enum": [
              "A0-claims-only",
              "A1-local-observed",
              "A2-isolated-observed",
              "A3-externally-attested"
            ]
          },
          "evaluator": {
            "type": "string",
            "minLength": 1
          },
          "hard": {
            "type": "boolean"
          }
        }
      }
    },
    "risk_gates": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "gate_id",
          "trigger",
          "safe_default",
          "required"
        ],
        "properties": {
          "gate_id": {
            "type": "string"
          },
          "trigger": {
            "type": "string"
          },
          "safe_default": {
            "type": "string"
          },
          "required": {
            "type": "boolean"
          }
        }
      }
    },
    "budgets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "limit",
          "unit",
          "policy",
          "observable"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "limit": {},
          "unit": {
            "type": "string"
          },
          "policy": {
            "enum": [
              "hard",
              "advisory"
            ]
          },
          "observable": {
            "type": "boolean"
          }
        }
      }
    },
    "compile_report_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    }
  }
}
