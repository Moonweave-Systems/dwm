{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://moonweave.systems/keelplane/schemas/gate-event-1.0.0.json",
  "title": "Keelplane Gate Event",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "gate_event_id",
    "gate_id",
    "run_id",
    "attempt_id",
    "plan_sha256",
    "action_digest",
    "scope",
    "state",
    "single_use",
    "approved_by",
    "origin"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "gate_event_id": {
      "type": "string",
      "minLength": 1
    },
    "gate_id": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string"
    },
    "attempt_id": {
      "type": "string"
    },
    "plan_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "action_digest": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "scope": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "effect",
        "description"
      ],
      "properties": {
        "effect": {
          "type": "string"
        },
        "description": {
          "type": "string"
        }
      }
    },
    "state": {
      "enum": [
        "declared",
        "requested",
        "approved",
        "denied",
        "executed",
        "expired",
        "not-applicable"
      ]
    },
    "single_use": {
      "type": "boolean"
    },
    "expires_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "approved_by": {
      "type": [
        "object",
        "null"
      ],
      "properties": {
        "kind": {
          "enum": [
            "human",
            "policy",
            "system"
          ]
        },
        "id": {
          "type": "string"
        },
        "authentication": {
          "type": "string"
        }
      },
      "required": [
        "kind",
        "id",
        "authentication"
      ],
      "additionalProperties": false
    },
    "origin": {
      "enum": [
        "self-reported",
        "imported",
        "local-observed",
        "runner-observed",
        "externally-attested"
      ]
    },
    "consumed_by_command_id": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "state": {
            "enum": [
              "approved",
              "executed"
            ]
          }
        },
        "required": [
          "state"
        ]
      },
      "then": {
        "properties": {
          "approved_by": {
            "type": "object"
          }
        },
        "required": [
          "approved_by"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "state": {
            "const": "executed"
          }
        },
        "required": [
          "state"
        ]
      },
      "then": {
        "properties": {
          "consumed_by_command_id": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "consumed_by_command_id"
        ]
      }
    }
  ]
}
