{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://moonweave.systems/keelplane/schemas/review-1.0.0.json",
  "title": "Keelplane Review",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "review_id",
    "reviewer_invocation_id",
    "producer_invocation_ids",
    "scope_digest",
    "input_artifact_refs",
    "independence",
    "verdict",
    "findings",
    "origin"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "review_id": {
      "type": "string",
      "minLength": 1
    },
    "reviewer_invocation_id": {
      "type": "string",
      "minLength": 1
    },
    "producer_invocation_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "scope_digest": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "input_artifact_refs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "independence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fresh_context",
        "same_model_as_producer",
        "same_harness_as_producer",
        "implementation_rationale_visible_before_findings",
        "human_reviewer"
      ],
      "properties": {
        "fresh_context": {
          "type": [
            "boolean",
            "string"
          ],
          "enum": [
            true,
            false,
            "unknown"
          ]
        },
        "same_model_as_producer": {
          "enum": [
            true,
            false,
            "unknown"
          ]
        },
        "same_harness_as_producer": {
          "enum": [
            true,
            false,
            "unknown"
          ]
        },
        "implementation_rationale_visible_before_findings": {
          "enum": [
            true,
            false,
            "unknown"
          ]
        },
        "human_reviewer": {
          "type": "boolean"
        }
      }
    },
    "verdict": {
      "enum": [
        "approved",
        "changes-requested",
        "refuted",
        "inconclusive"
      ]
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "finding_id",
          "severity",
          "summary",
          "evidence_refs",
          "disposition"
        ],
        "properties": {
          "finding_id": {
            "type": "string"
          },
          "severity": {
            "enum": [
              "critical",
              "high",
              "medium",
              "low",
              "info"
            ]
          },
          "summary": {
            "type": "string"
          },
          "path": {
            "type": [
              "string",
              "null"
            ]
          },
          "evidence_refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "disposition": {
            "enum": [
              "must-fix",
              "should-fix",
              "consider",
              "none"
            ]
          }
        }
      }
    },
    "origin": {
      "enum": [
        "self-reported",
        "imported",
        "local-observed",
        "runner-observed",
        "externally-attested"
      ]
    }
  }
}
