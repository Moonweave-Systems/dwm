{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://moonweave.systems/keelplane/schemas/evidence-manifest-1.0.0.json",
  "title": "Keelplane Evidence Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "attempt_id",
    "captured_at",
    "decision_state",
    "assurance",
    "plan",
    "subject",
    "collector",
    "harness",
    "invocations",
    "agent_results",
    "artifacts",
    "commands",
    "reviews",
    "gates",
    "budgets",
    "redaction",
    "retention",
    "ledger",
    "warnings"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "run_id": {
      "type": "string"
    },
    "attempt_id": {
      "type": "string"
    },
    "decision_state": {
      "const": "not-evaluated"
    },
    "assurance": {
      "enum": [
        "A0-claims-only",
        "A1-local-observed",
        "A2-isolated-observed",
        "A3-externally-attested"
      ]
    },
    "plan": {
      "type": "object",
      "required": [
        "path",
        "sha256"
      ],
      "properties": {
        "path": {
          "type": "string"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      },
      "additionalProperties": false
    },
    "run_contract": {
      "type": [
        "object",
        "null"
      ],
      "required": [
        "path",
        "sha256"
      ],
      "properties": {
        "path": {
          "type": "string"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      },
      "additionalProperties": false
    },
    "subject": {
      "type": "object",
      "required": [
        "kind",
        "repository",
        "repository_label",
        "repository_locator_sha256",
        "head",
        "dirty",
        "snapshot_sha256",
        "status_sha256",
        "index_diff_sha256",
        "worktree_diff_sha256",
        "untracked_sha256",
        "submodules_sha256"
      ],
      "properties": {
        "kind": {
          "const": "git-repository"
        },
        "repository": {
          "type": "string"
        },
        "head": {
          "type": "string"
        },
        "dirty": {
          "type": "boolean"
        },
        "snapshot_sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "status_sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "index_diff_sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "worktree_diff_sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "untracked_sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "submodules_sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "repository_label": {
          "type": "string",
          "minLength": 1
        },
        "repository_locator_sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      },
      "additionalProperties": false
    },
    "collector": {
      "type": "object",
      "required": [
        "name",
        "version",
        "origin",
        "platform",
        "python",
        "git"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "origin": {
          "enum": [
            "self-reported",
            "imported",
            "local-observed",
            "runner-observed",
            "externally-attested"
          ]
        },
        "platform": {
          "type": "string"
        },
        "python": {
          "type": "string"
        },
        "git": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "harness": {
      "type": "object",
      "required": [
        "name",
        "auth_mode"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "version": {
          "type": [
            "string",
            "null"
          ]
        },
        "auth_mode": {
          "enum": [
            "subscription-declared",
            "api-key-declared",
            "unknown"
          ]
        },
        "session_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "invocations": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "artifact_id",
          "path",
          "sha256",
          "size_bytes",
          "origin"
        ],
        "properties": {
          "artifact_id": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "size_bytes": {
            "type": "integer",
            "minimum": 0
          },
          "media_type": {
            "type": "string"
          },
          "origin": {
            "enum": [
              "self-reported",
              "imported",
              "local-observed",
              "runner-observed",
              "externally-attested"
            ]
          },
          "redacted": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      }
    },
    "commands": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "reviews": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "gates": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "budgets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "limit",
          "observed",
          "unit",
          "source",
          "policy"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "limit": {},
          "observed": {},
          "unit": {
            "type": "string"
          },
          "source": {
            "type": "string"
          },
          "policy": {
            "enum": [
              "hard",
              "advisory"
            ]
          }
        },
        "additionalProperties": false
      }
    },
    "redaction": {
      "type": "object",
      "required": [
        "policy_sha256",
        "content_capture"
      ],
      "properties": {
        "policy_sha256": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^[a-f0-9]{64}$"
        },
        "content_capture": {
          "enum": [
            "metadata-only",
            "allowlisted-content",
            "full-content-approved"
          ]
        }
      },
      "additionalProperties": false
    },
    "retention": {
      "enum": [
        "ephemeral",
        "project",
        "release"
      ]
    },
    "ledger": {
      "type": "object",
      "required": [
        "path",
        "sha256"
      ],
      "properties": {
        "path": {
          "type": "string"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      },
      "additionalProperties": false
    },
    "event_log": {
      "type": [
        "object",
        "null"
      ]
    },
    "attestations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "captured_at": {
      "type": "string",
      "format": "date-time"
    },
    "agent_results": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
