{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://moonweave.systems/keelplane/schemas/seal-1.0.0.json",
  "title": "Keelplane Local Seal",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "attempt_id",
    "manifest_sha256",
    "ledger_sha256",
    "sealed_paths_sha256",
    "sealed_at",
    "sealer",
    "signature",
    "assurance"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "run_id": {
      "type": "string"
    },
    "attempt_id": {
      "type": "string"
    },
    "manifest_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "ledger_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "sealed_paths_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "sealed_at": {
      "type": "string",
      "format": "date-time"
    },
    "sealer": {
      "type": "object",
      "required": [
        "name",
        "version",
        "origin"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "origin": {
          "const": "local-observed"
        }
      },
      "additionalProperties": false
    },
    "signature": {
      "type": [
        "object",
        "null"
      ]
    },
    "assurance": {
      "const": "A1-local-observed"
    }
  }
}
