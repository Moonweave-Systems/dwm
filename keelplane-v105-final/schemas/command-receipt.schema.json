{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://moonweave.systems/keelplane/schemas/command-receipt-1.0.0.json",
  "title": "Keelplane Command Receipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "command_id",
    "invocation_id",
    "origin",
    "argv",
    "shell",
    "cwd",
    "source_snapshot_sha256",
    "status",
    "timeout_ms",
    "stdout",
    "stderr"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "command_id": {
      "type": "string",
      "minLength": 1
    },
    "invocation_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "origin": {
      "enum": [
        "self-reported",
        "imported",
        "local-observed",
        "runner-observed",
        "externally-attested"
      ]
    },
    "argv": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "shell": {
      "type": "boolean"
    },
    "shell_executable": {
      "type": [
        "string",
        "null"
      ]
    },
    "cwd": {
      "type": "string"
    },
    "source_snapshot_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "started_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "finished_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "duration_ms": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 0
    },
    "status": {
      "enum": [
        "exited",
        "signaled",
        "timed-out",
        "blocked",
        "not-run",
        "capture-error"
      ]
    },
    "exit_code": {
      "type": [
        "integer",
        "null"
      ]
    },
    "signal": {
      "type": [
        "integer",
        "string",
        "null"
      ]
    },
    "timeout_ms": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 0
    },
    "stdout": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "sha256",
        "size_bytes",
        "truncated"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "size_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "truncated": {
          "type": "boolean"
        }
      }
    },
    "stderr": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "sha256",
        "size_bytes",
        "truncated"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "size_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "truncated": {
          "type": "boolean"
        }
      }
    },
    "redaction_policy_sha256": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^[a-f0-9]{64}$"
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "const": "exited"
          }
        },
        "required": [
          "status"
        ]
      },
      "then": {
        "properties": {
          "exit_code": {
            "type": "integer"
          }
        },
        "required": [
          "exit_code"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "const": "signaled"
          }
        },
        "required": [
          "status"
        ]
      },
      "then": {
        "properties": {
          "signal": {
            "type": [
              "integer",
              "string"
            ]
          }
        },
        "required": [
          "signal"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "shell": {
            "const": true
          }
        },
        "required": [
          "shell"
        ]
      },
      "then": {
        "properties": {
          "shell_executable": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "shell_executable"
        ]
      }
    }
  ]
}
