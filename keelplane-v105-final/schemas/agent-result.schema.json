{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://moonweave.systems/keelplane/schemas/agent-result-1.0.0.json",
  "title": "Keelplane Agent Result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "attempt_id",
    "invocation_id",
    "agent_name",
    "role",
    "harness",
    "status",
    "source_snapshot_sha256",
    "scope",
    "summary",
    "claims",
    "artifact_refs",
    "command_refs",
    "blockers",
    "origin"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "attempt_id": {
      "type": "string",
      "minLength": 1
    },
    "invocation_id": {
      "type": "string",
      "minLength": 1
    },
    "parent_invocation_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "agent_name": {
      "type": "string",
      "minLength": 1
    },
    "role": {
      "enum": [
        "explorer",
        "implementer",
        "test-verifier",
        "code-reviewer",
        "security-reviewer",
        "adversarial-reviewer",
        "lead",
        "integration-owner",
        "other"
      ]
    },
    "harness": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": [
        "completed",
        "blocked",
        "failed",
        "cancelled"
      ]
    },
    "source_snapshot_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "read",
        "write"
      ],
      "properties": {
        "read": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "write": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "summary": {
      "type": "string"
    },
    "claims": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "claim_id",
          "statement",
          "evidence_refs",
          "producer_state"
        ],
        "properties": {
          "claim_id": {
            "type": "string",
            "minLength": 1
          },
          "statement": {
            "type": "string",
            "minLength": 1
          },
          "evidence_refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "producer_state": {
            "enum": [
              "asserted",
              "challenged",
              "self-refuted",
              "unknown"
            ]
          }
        }
      }
    },
    "artifact_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "command_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "residual_risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "origin": {
      "const": "self-reported"
    }
  }
}
