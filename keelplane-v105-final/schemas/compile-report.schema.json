{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://moonweave.systems/keelplane/schemas/compile-report-1.0.0.json",
  "title": "Keelplane Native Compile Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "plan_sha256",
    "target",
    "capability_snapshot_sha256",
    "overall_status",
    "mappings",
    "warnings"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "plan_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "harness",
        "version"
      ],
      "properties": {
        "harness": {
          "type": "string"
        },
        "version": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "capability_snapshot_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "overall_status": {
      "enum": [
        "ready",
        "ready-with-warnings",
        "blocked"
      ]
    },
    "mappings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "plan_feature",
          "status",
          "native_mapping",
          "reason",
          "critical"
        ],
        "properties": {
          "plan_feature": {
            "type": "string"
          },
          "status": {
            "enum": [
              "exact",
              "approximated",
              "omitted-noncritical",
              "unsupported-critical"
            ]
          },
          "native_mapping": {
            "type": [
              "string",
              "null"
            ]
          },
          "reason": {
            "type": "string"
          },
          "critical": {
            "type": "boolean"
          }
        }
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
