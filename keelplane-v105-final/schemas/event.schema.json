{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://moonweave.systems/keelplane/schemas/event-1.0.0.json",
  "title": "Keelplane Observed Event",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "attempt_id",
    "seq",
    "event_type",
    "payload_sha256",
    "previous_event_sha256",
    "event_sha256",
    "origin"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "attempt_id": {
      "type": "string",
      "minLength": 1
    },
    "seq": {
      "type": "integer",
      "minimum": 0
    },
    "event_type": {
      "type": "string",
      "minLength": 1
    },
    "invocation_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "payload_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "previous_event_sha256": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^[a-f0-9]{64}$"
    },
    "event_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "timestamp": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "timestamp_source": {
      "enum": [
        "local-clock",
        "runner-clock",
        "trusted-timestamp",
        "unknown"
      ]
    },
    "origin": {
      "enum": [
        "local-observed",
        "runner-observed",
        "externally-attested"
      ]
    }
  }
}
